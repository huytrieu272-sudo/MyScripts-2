-- 1. Loop Kill Aura, Auto Clicker & Teleport Kill VIP
task.spawn(function()
    while task.wait(_G.PvPSettings.ClickDelay) do
        if _G.PvPSettings.KillAura or _G.PvPSettings.AutoClick or _G.PvPSettings.TeleportKill then
            pcall(function()
                local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    tool:Activate()
                    if _G.PvPSettings.AutoBlock and tool:FindFirstChild("Block") then tool.Block:FireServer(true) end
                    
                    local targetPlayer = nil
                    local lowestHealth = math.huge
                    
                    if myHrp then
                        for _, p in ipairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") then
                                local hum = p.Character.Humanoid
                                if hum.Health > 0 and (not _G.PvPSettings.TeamCheck or p.Team ~= LocalPlayer.Team) then
                                    local enemyHrp = p.Character.HumanoidRootPart
                                    local distance = (myHrp.Position - enemyHrp.Position).Magnitude
                                    
                                    if distance <= _G.PvPSettings.AuraRange then
                                        if hum.Health < lowestHealth then
                                            lowestHealth = hum.Health
                                            targetPlayer = p
                                        end
                                        if _G.PvPSettings.KillAura then
                                            if tool:FindFirstChild("RemoteEvent") then tool.RemoteEvent:FireServer(enemyHrp.Position) end
                                            if tool:FindFirstChild("Hit") then tool.Hit:FireServer(p.Character) end
                                        end
                                    end
                                end
                            end
                        end
                        
                        -- Thực hiện Teleport sau lưng mục tiêu yếu máu nhất trong tầm quét
                        if _G.PvPSettings.TeleportKill and targetPlayer and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            myHrp.CFrame = targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                        end
                    end
                end
            end)
        end
    end
end)

-- 2. Aimlock Cơ Chế Dự Đoán Quỹ Đạo (Prediction VIP)
local function GetClosestPlayerInFOV()
    local closestPlayer = nil local shortestDistance = math.huge
    local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myHrp then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(_G.PvPSettings.AimPart) and p.Character:FindFirstChildOfClass("Humanoid") then
            if p.Character.Humanoid.Health > 0 and (not _G.PvPSettings.TeamCheck or p.Team ~= LocalPlayer.Team) then
                local pos, onScreen = Camera:WorldToViewportPoint(p.Character[_G.PvPSettings.AimPart].Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                    if (not _G.PvPSettings.FOVCircle or dist <= _G.PvPSettings.FOVRadius) and dist < shortestDistance then
                        closestPlayer = p shortestDistance = dist
                    end
                end
            end
        end
    end
    return closestPlayer
end

RunService.RenderStepped:Connect(function()
    if _G.PvPSettings.Aimlock then
        pcall(function()
            local target = GetClosestPlayerInFOV()
            if target and target.Character and target.Character:FindFirstChild(_G.PvPSettings.AimPart) then
                local targetPart = target.Character[_G.PvPSettings.AimPart]
                local targetPos = targetPart.Position
                
                -- Tính toán độ lệch di chuyển của đối phương để bám tâm đón đầu (Prediction)
                if _G.PvPSettings.Prediction and target.Character:FindFirstChild("HumanoidRootPart") then
                    local velocity = target.Character.HumanoidRootPart.Velocity
                    local ping = 0.12 -- Hệ số trễ tối ưu hóa thuật toán đón đầu
                    targetPos = targetPos + (velocity * ping)
                end
                
                if _G.PvPSettings.AimSmoothness <= 1 then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                else
                    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPos), 1 / _G.PvPSettings.AimSmoothness)
                end
            end
        end)
    end
    
    -- Chức năng Spinbot / AntiAim độc quyền chống khóa tâm từ địch
    if _G.PvPSettings.AntiAim then
        pcall(function()
            local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if myHrp then
                myHrp.CFrame = myHrp.CFrame * CFrame.Angles(0, math.rad(45), 0)
            end
        end)
    end
end)

