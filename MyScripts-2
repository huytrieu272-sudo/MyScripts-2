local function get_key_remaining_time()
    local keyData = LocalDatabase[CurrentActiveKey]
    if not keyData then return 0 end
    if keyData.isFrozen then return keyData.duration end
    local remaining = keyData.expires - os.time()
    return math.max(0, remaining)
end

