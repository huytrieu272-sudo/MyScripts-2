-- [9. HỆ THỐNG GIAO DIỆN NHẬP KEY RAYFIELD ĐẸP MẮT TRỰC QUAN]
-- =============================================================================
local function InitKeyVerificationSystem()
    if isfile and isfile(KEY_FILE) then
        local success, savedKey = pcall(readfile, KEY_FILE)
        if success and savedKey and LocalDatabase[savedKey] then
            local data = LocalDatabase[savedKey]
            if data.isFrozen or (data.expires > os.time()) then
                CurrentActiveKey = savedKey
                local state, err = pcall(function() LaunchMainMenu(get_key_remaining_time()) end)
                if not state then warn("Lỗi khởi chạy Main Menu: " .. tostring(err)) end
                return
            end
        end
    end

    -- Sử dụng link Github dự phòng để luôn tải được UI
    local RayfieldKey = loadstring(game:HttpGet('https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua'))()
    local KeyWindow = RayfieldKey:CreateWindow({
        Name = "TRUNG KIEN HUB 🔥 | HỆ THỐNG XÁC THỰC KEY",
        LoadingTitle = "Xác Thực Hệ Thống Key...",
        LoadingSubtitle = "Vui lòng nhập key",
        ConfigurationSaving = { Enabled = false }
    })

    local CheckTab = KeyWindow:CreateTab("Verify Key", 4483362458)
    CheckTab:CreateLabel("🔑 [VUI LÒNG NHẬP KEY OFFLINE ĐỂ TIẾP TỤC]")

    local InputtedKeyString = ""

    CheckTab:CreateInput({
        Name = "Nhập mã Key của bạn vào đây",
        PlaceholderText = "Mã Key của bạn...",
        RemoveTextAfterFocusLost = false,
        Callback = function(text)
            InputtedKeyString = text
        end
    })

    CheckTab:CreateButton({
        Name = "⚡ KIỂM TRA & KÍCH HOẠT KEY",
        Callback = function()
            local keyData = LocalDatabase[InputtedKeyString]
            if keyData then
                local currentHwid = getHWID()
                if keyData.hwid == nil then
                    keyData.hwid = currentHwid
                    keyData.expires = os.time() + keyData.duration
                    save_global_db()
                elseif keyData.hwid ~= currentHwid then
                    RayfieldKey:Notify({Title = "THẤT BẠI", Content = "Key này đã được đăng ký cho thiết bị (HWID) khác!", Duration = 5})
                    return
                end

                if not keyData.isFrozen and os.time() > keyData.expires then
                    RayfieldKey:Notify({Title = "THẤT BẠI", Content = "Mã Key này hiện đã hết hạn sử dụng!", Duration = 5})
                    return
                end

                CurrentActiveKey = InputtedKeyString
                if writefile then pcall(writefile, KEY_FILE, InputtedKeyString) end
                
                RayfieldKey:Notify({Title = "THÀNH CÔNG", Content = "Xác thực Key thành công! Đang tải menu...", Duration = 3})
                task.wait(1)
                KeyWindow:Destroy()
                local state, err = pcall(function() LaunchMainMenu(get_key_remaining_time()) end)
                if not state then warn("Lỗi mở menu sau nhập key: " .. tostring(err)) end
            else
                RayfieldKey:Notify({Title = "LỖI", Content = "Mã Key bạn nhập không hợp lệ hoặc sai cấu trúc!", Duration = 5})
            end
        end
    })

    CheckTab:CreateButton({
        Name = "📋 SAO CHÉP MÃ THIẾT BỊ (COPY HWID)",
        Callback = function()
            if setclipboard then
                setclipboard(getHWID())
                RayfieldKey:Notify({Title = "THÔNG BÁO", Content = "Đã sao chép mã HWID vào khay nhớ tạm!", Duration = 3})
            end
        end
    })
end

-- Chạy hệ thống kiểm tra qua pcall để tránh đứng luồng chính nếu Executor lỗi kết nối mạng cục bộ
pcall(InitKeyVerificationSystem)
