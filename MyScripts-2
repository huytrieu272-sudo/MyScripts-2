        Name = "Bật Hiệu Ứng 7 Sắc Cầu Vồng (Chroma RGB)",
        CurrentValue = false,
        Callback = function(v) _G.Features.RGBTheme = v end,
    })

    SettingTab:CreateDropdown({
        Name = "Thay Đổi Tông Màu Chủ Đạo Giao Diện",
        Options = {"Mặc định (Xanh Cyan)", "Đỏ Hủy Diệt (Ruby)", "Tím Huyền Ảo (Neon)", "Hồng Cá Tính (HotPink)", "Vàng Hoàng Gia (Gold)", "Xanh Lá Cây (Lime)"},
        CurrentOption = "Mặc định (Xanh Cyan)",
        MultipleOptions = false,
        Callback = function(v)
            local choice = v[1] or v
            if choice == "Mặc định (Xanh Cyan)" then _G.Features.SelectedThemeColor = Color3.fromRGB(0, 255, 230)
            elseif choice == "Đỏ Hủy Diệt (Ruby)" then _G.Features.SelectedThemeColor = Color3.fromRGB(255, 30, 30)
            elseif choice == "Tím Huyền Ảo (Neon)" then _G.Features.SelectedThemeColor = Color3.fromRGB(180, 30, 255)
            elseif choice == "Hồng Cá Tính (HotPink)" then _G.Features.SelectedThemeColor = Color3.fromRGB(255, 105, 180)
            elseif choice == "Vàng Hoàng Gia (Gold)" then _G.Features.SelectedThemeColor = Color3.fromRGB(255, 215, 0)
            elseif choice == "Xanh Lá Cây (Lime)" then _G.Features.SelectedThemeColor = Color3.fromRGB(50, 255, 50) end
        end,
    })

    SettingTab:CreateLabel("🚀 HỆ THỐNG TỐI ƯU HÓA ENGINE GAME")
    SettingTab:CreateToggle({
        Name = "Bật Siêu Cấp Mượt Mà (Anti-Lag Cực Hạn)",
        CurrentValue = false,
        Callback = function(v)
            _G.Features.AntiLag = v
            if v then
                pcall(function()
                    Lighting.GlobalShadows = false
                    Lighting.FogEnd = 9e9
                    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
                    for _, obj in pairs(workspace:GetDescendants()) do
                        if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
                            if not OriginalGraphics[obj] then
                                OriginalGraphics[obj] = { Material = obj.Material, Reflectance = obj.Reflectance }
                            end
                            obj.Material = Enum.Material.SmoothPlastic
                            obj.Reflectance = 0
                        elseif obj:IsA("Decal") or obj:IsA("Texture") then
                            if not OriginalGraphics[obj] then OriginalGraphics[obj] = { Visible = obj.Visible } end
                            obj.Visible = false
                        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
                            if not OriginalGraphics[obj] then OriginalGraphics[obj] = { Enabled = obj.Enabled } end
                            obj.Enabled = false
                        end
                    end
                end)
            else
                pcall(function()
                    Lighting.GlobalShadows = true
                    settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
                    for obj, data in pairs(OriginalGraphics) do
                        if obj and obj.Parent then
                            if data.Material then obj.Material = data.Material end
                            if data.Reflectance then obj.Reflectance = data.Reflectance end
                            if data.Visible ~= nil then obj.Visible = data.Visible end
                            if data.Enabled ~= nil then obj.Enabled = data.Enabled end
                        end
                    end
                    table.clear(OriginalGraphics)
                end)
            end
        end,
    })

    SettingTab:CreateButton({
        Name = "Xóa Session Key Đã Lưu",
        Callback = function() if delfile then delfile(KEY_FILE) end end,
    })
end

-- THUẬT TOÁN ÉP MÀU TĨNH VÀ MÀU 7 SẮC CẦU VỒNG (CHROMA RGB) SIÊU MƯỢT
task.spawn(function()
    while task.wait(0.01) do
        pcall(function()
            local TargetColor = _G.Features.SelectedThemeColor
            if _G.Features.RGBTheme then
                local hue = (tick() % 4) / 4 -- Chu kỳ đổi sắc cầu vồng cực đẹp
                TargetColor = Color3.fromHSV(hue, 1, 1)
            end
            
            -- Tìm kiếm và thay thế toàn bộ Color của Rayfield UI đang hiển thị trên CoreGui
            if game:GetService("CoreGui"):FindFirstChild("Rayfield") then
                local RayfieldGui = game:GetService("CoreGui").Rayfield
                for _, element in pairs(RayfieldGui:GetDescendants()) do
                    -- Ép màu cho các đường viền, dải màu phân cách
                    if element:IsA("Frame") and (element.Name == "Line" or element.Name == "Stroke" or element.Name == "Selected") then
                        element.BackgroundColor3 = TargetColor
                    -- Ép màu cho các UI Stroke hiện đại
                    elseif element:IsA("UIStroke") then
                        element.Color = TargetColor
                    -- Ép màu cho chữ tiêu đề, Label nổi bật
                    elseif element:IsA("TextLabel") and (element.TextColor3 == Color3.fromRGB(0, 255, 230) or element.Name == "Title" or element.Name == "WindowTab") then
                        element.TextColor3 = TargetColor
                    -- Ép màu cho các Image nhấp nháy, Icon tab đang chọn
                    elseif element:IsA("ImageLabel") and element.ImageColor3 == Color3.fromRGB(0, 255, 230) then
                        element.ImageColor3 = TargetColor
                    end
                end
            end
        end)
    end
end)

