local function auto_login()
    if isfile and isfile(KEY_FILE) then
        local success, saved_key = pcall(readfile, KEY_FILE)
        if success and LocalDatabase[saved_key] then
            local keyData = LocalDatabase[saved_key]
            if keyData.hwid == getHWID() then
                if keyData.isFrozen then
                    keyData.expires = os.time() + keyData.duration
                    keyData.isFrozen = false
                    save_global_db()
                end
                if (keyData.expires - os.time()) > 0 then
                    CurrentActiveKey = saved_key
                    return true
                end
            end
        end
    end
    return false
end

